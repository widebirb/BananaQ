# GitHub
GITHUB_TOKEN=ghp_...              # Bot account PAT — needs: repo, pull_requests scopes
GITHUB_WEBHOOK_SECRET=...         # Random string — set the same in GitHub repo webhook settings
GITHUB_REPO=owner/repo-name       # e.g. widebirb/BQTR

# LLM (Ollama — OpenAI-compatible endpoint)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5-coder:1.5b   # swap to qwen3:4b on vast.ai

# Tuning
MAX_REVIEW_COMMENTS=10

# Server
HOST=0.0.0.0
PORT=8000
